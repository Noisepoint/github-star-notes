{
  "manifest_version": 3,
  "name": "GitHub Star Notes",
  "version": "0.1.2",
  "description": "在 GitHub 仓库页添加本地私人备注，并在 Stars 列表页展示。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://github.com/*"],
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": [
        "src/storage.js",
        "src/github-page.js",
        "src/import-export.js",
        "src/ui.js",
        "src/content.js"
      ],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
